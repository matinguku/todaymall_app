    "@react-native/metro-config": "^0.81.4",
    "@types/lodash": "^4.14.202",
    "@types/react": "~19.1.10",
    "@types/react-native-vector-icons": "^6.4.18",
    "babel-plugin-transform-inline-environment-variables": "^0.4.4",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "concurrently": "^9.1.2",
    "typescript": "~5.9.2",
    "wait-on": "^8.0.1"
