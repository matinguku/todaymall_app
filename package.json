{
  "name": "todaymall",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "node ./scripts/adbReverse.js && react-native start --custom-log-reporter-path ./scripts/metroFilteredReporter.js",
    "start:reset": "node ./scripts/adbReverse.js && react-native start --reset-cache --custom-log-reporter-path ./scripts/metroFilteredReporter.js",
    "android": "node ./scripts/run-android.js",
    "android:clean": "cd android && ./gradlew clean && cd .. && node ./scripts/run-android.js",
    "dev:android": "concurrently -n metro,android -c cyan,green \"npm run start\" \"npx wait-on tcp:127.0.0.1:8081 && npm run android\"",
    "ios": "react-native run-ios",
    "adb:reverse": "node ./scripts/adbReverse.js"
  },
  "dependencies": {
    "@d11/react-native-fast-image": "^8.13.0",
    "@gorhom/bottom-sheet": "^5.2.6",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-camera-roll/camera-roll": "^7.10.2",
    "@react-native-clipboard/clipboard": "^1.14.1",
    "@react-native-community/cli": "latest",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-google-signin/google-signin": "^16.0.0",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@reduxjs/toolkit": "^2.2.6",
    "axios": "^1.12.2",
    "js-sha256": "^0.11.1",
    "lodash": "^4.17.21",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "react-native-config": "^1.6.1",
    "react-native-confirmation-code-field": "^8.0.1",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-image-crop-picker": "^0.51.0",
    "react-native-image-picker": "^7.1.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-orientation-locker": "^1.7.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-svg-transformer": "^1.5.1",
    "react-native-vector-icons": "^10.3.0",
    "react-native-view-shot": "^4.0.3",
